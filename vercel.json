{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://SEU-BACKEND-URL.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://SEU-BACKEND-URL.railway.app/uploads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
